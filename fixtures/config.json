{
  "version": "1.0.0",
  "envFile":".env.development",
  "credentials": {
    "Name":"${DB_NAME}",
    "username": "${DB_ROOT_USER}",
    "password": "${DB_PASSWORD}",
    "host": "${DB_HOST}",
    "port": "${DB_PORT}"
  },
  "databases": [
    {
      "name": "courses_db",
      "scripts": [
        {
          "order": 1,
          "path": "services/courses/sql/__init.sql",
          "isDirectory": false
        },
        {
          "order": 2,
          "path": "services/courses/sql/schema.sql",
          "isDirectory": false
        },
        {
          "order": 3,
          "path": "services/courses/sql/procedures/*.sql",
          "isDirectory": true
        },
        {
          "order": 4,
          "path": "services/courses/sql/functions/*.sql",
          "isDirectory": true
        }
      ],

      "data":[
           {
            "name":"courses_db",
            "type":"csv",
            "filePath":""
           }
          
      ]
    },
    {
      "name": "email_db",
      "scripts": [
        {
          "order": 1,
          "path": "services/email/sql/__init.sql",
          "isDirectory": false
        },
        {
          "order": 2,
          "path": "services/email/sql/schema/*.sql",
          "isDirectory": true
        },
        {
          "order": 3,
          "path": "services/email/sql/procedures/*.sql",
          "isDirectory": true
        },
        {
          "order": 4,
          "path": "services/email/sql/functions/*.sql",
          "isDirectory": true
        }
      ]
    },
    {
      "name":"users_db",
      "scripts": [
        {
          "order": 1,
          "path": "services/users_api/sql/__init.sql",
          "isDirectory": false
        },
        {
          "order": 2,
          "path": "services/users_api/sql/tables/*.sql",
          "isDirectory": true
        },
        {
          "order": 3,
          "path": "services/users_api/sql/procedures/*.sql",
          "isDirectory": true
        }
      ]
    }
  ],

  "migrations":[
     {
      "name":"users_db",
      "reset": true,
      "ingestions":[
        {
          "name":"users_db.CreateNewUser",
          "parameters":["email","name", "surname", "phonenumber", "ipaddress", "agent"],
          "path":"../../fixtures/csv/*.csv",
          "isProcedure": true
        }
      ]
     }
  ]

}